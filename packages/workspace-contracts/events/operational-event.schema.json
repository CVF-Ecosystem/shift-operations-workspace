{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Operational Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "shift_id",
    "event_type",
    "title",
    "risk_class",
    "state",
    "evidence"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "shift_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "risk_class": {
      "enum": [
        "R0",
        "R1",
        "R2",
        "R3",
        "R4"
      ]
    },
    "state": {
      "enum": [
        "RAW",
        "NORMALIZED",
        "PROPOSED",
        "CONFIRMED",
        "REJECTED",
        "CORRECTED",
        "FROZEN"
      ]
    },
    "starts_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "ends_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
