{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Event Proposal",
  "type": "object",
  "required": [
    "proposal_id",
    "source_message_ids",
    "event",
    "confidence",
    "missing_fields"
  ],
  "properties": {
    "proposal_id": {
      "type": "string",
      "format": "uuid"
    },
    "source_message_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "event": {
      "$ref": "operational-event.schema.json"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "missing_fields": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requires_human_confirmation": {
      "type": "boolean"
    }
  }
}
