    "send",
    "attachments",
    "delivery_status"
  ],
  "properties": {
    "receive": {
      "type": "boolean"
    },
    "send": {
      "type": "boolean"
    },
    "attachments": {
      "type": "boolean"
    },
    "delivery_status": {
      "type": "boolean"
    },
