{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Channel Adapter",
  "type": "object",
  "required": [
    "adapter_id",
    "provider",
    "capabilities"
  ],
  "properties": {
    "adapter_id": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "official_connector_required": {
      "type": "boolean"
    }
  }
}
