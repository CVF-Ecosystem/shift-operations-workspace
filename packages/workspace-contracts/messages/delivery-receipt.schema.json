{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Delivery Receipt",
  "type": "object",
  "required": [
    "message_id",
    "provider",
    "status",
    "occurred_at"
  ],
  "properties": {
    "message_id": {
      "type": "string"
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "queued",
        "sent",
        "delivered",
        "read",
        "failed"
      ]
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
