{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Canonical Attachment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "attachment_id",
    "filename",
    "media_type",
    "size_bytes",
    "sha256",
    "status"
  ],
  "properties": {
    "attachment_id": {
      "type": "string",
      "format": "uuid"
    },
    "filename": {
      "type": "string",
      "minLength": 1
    },
    "media_type": {
      "type": "string",
      "minLength": 1
    },
    "size_bytes": {
      "type": "integer",
      "minimum": 0
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{64}$"
    },
    "status": {
      "enum": [
        "received",
        "validated",
        "quarantined",
        "stored"
      ]
    },
    "storage_ref": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
