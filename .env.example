APP_ENV=development
APP_NAME=Shift Operations Workspace
API_HOST=0.0.0.0
API_PORT=8000
EDGE_PORT=8100
DATABASE_URL=postgresql+psycopg://workspace:workspace@postgres:5432/workspace
REDIS_URL=redis://redis:6379/0
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
OBJECT_STORAGE_BUCKET=workspace-evidence
WEBHOOK_SHARED_SECRET=replace-me
# P2-B (real authentication): no default in Settings - the app refuses to
# start without a real value. Signs/verifies JWT access tokens.
JWT_SECRET_KEY=replace-me-with-a-real-secret
JWT_ACCESS_TOKEN_TTL_MINUTES=60
AI_MODE=NO_AI
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
DAILY_AI_BUDGET_USD=5
MONTHLY_AI_BUDGET_USD=100
