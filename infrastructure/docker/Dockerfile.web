FROM node:22-alpine AS build
WORKDIR /app
COPY apps/workspace-web/package.json apps/workspace-web/tsconfig.json apps/workspace-web/vite.config.ts apps/workspace-web/index.html ./
COPY apps/workspace-web/src ./src
COPY apps/workspace-web/public ./public
RUN corepack enable && pnpm install && pnpm build
FROM nginx:1.27-alpine
COPY --from=build /app/dist /usr/share/nginx/html
